DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id
MORALIS_API_KEY=your_moralis_api_key
LOG_CHANNEL_ID=your_log_channel_id
TZ=UTC

# Optional: comma-separated chains for auto-track (default: solana,ethereum,base,bsc,abstract)
# ENABLED_CHAINS=solana,ethereum,base,bsc,abstract

# Optional API keys (rug / research commands)
ANTHROPIC_API_KEY=
TWITTERAPI_KEY=
BITQUERY_API_KEY=
RUGCHECK_API_KEY=
HELIUS_API_KEY=
DATABASE_URL=file:./research.db

# --- Alert gate (maintenance & comeback) ---
# MAINTENANCE_MODE=1          — suppress milestone/price alerts; bot still polls and new CA confirmations still post
# COMEBACK_SILENCE_CYCLES=3   — on deploy: N poll cycles sync milestone state only, then alerts auto-resume
#
# --- Railway persistence (required for 500+ tokens) ---
# Mount a volume at /data — tracked.json + milestone state live there automatically.
# Without /data volume, redeploys wipe milestone history → catch-up alert spam.
