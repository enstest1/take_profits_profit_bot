DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id
MORALIS_API_KEY=your_moralis_api_key
LOG_CHANNEL_ID=your_log_channel_id
TZ=UTC

# Optional API keys (rug / research commands)
ANTHROPIC_API_KEY=
TWITTERAPI_KEY=
BITQUERY_API_KEY=
RUGCHECK_API_KEY=
HELIUS_API_KEY=
DATABASE_URL=file:./research.db

# --- Alert gate (maintenance & comeback) ---
# MAINTENANCE_MODE=1          — suppress ALL Discord alerts; bot still polls and updates /data
# COMEBACK_SILENCE_CYCLES=3   — on deploy: N poll cycles sync DB only, then alerts auto-resume
